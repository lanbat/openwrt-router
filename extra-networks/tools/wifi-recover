#!/bin/sh /etc/rc.common
# Recovers WiFi radios whose VAPs were lost to the mac80211 race condition
# triggered by wifi reload on MT7986. Safe on any OpenWrt machine: if VAPs
# are already up the script exits without doing anything.
START=99

_recover_phy() {
    _phy="$1"; _hconf="$2"
    _attempt=0
    while [ "$_attempt" -lt 5 ]; do
        iw dev 2>/dev/null | grep -q "Interface ${_phy}-ap0" && return 0
        logger -t wifi-recover "${_phy}: primary VAP missing (attempt $((_attempt+1))), recovering via hostapd config_set"
        ubus call hostapd config_set \
            "{\"phy\":\"${_phy}\",\"radio\":-1,\"config\":\"${_hconf}\",\"prev_config\":\"${_hconf}.prev\"}" \
            >/dev/null 2>&1 || true
        sleep 3
        _attempt=$((_attempt+1))
    done
    logger -t wifi-recover "${_phy}: gave up after 5 attempts"
}

start() {
    sleep 5
    for _hconf in /var/run/hostapd-*.conf; do
        [ -f "$_hconf" ] || continue
        _phy="${_hconf##*/hostapd-}"; _phy="${_phy%.conf}"
        iw dev 2>/dev/null | grep -q "Interface ${_phy}-ap0" && continue
        _recover_phy "$_phy" "$_hconf"
    done
}
