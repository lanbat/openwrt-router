# Copy to configs/untrusted.conf and set WIFI_KEY before running:
#   sh install.sh configs/untrusted.conf
# configs/*.conf is gitignored and never committed.

WIFI_KEY=                        # min 8 chars

IFACE=untrusted
RADIO=radio0                     # radio0 = 2.4GHz, radio1 = 5GHz
RADIO_EXTRA=                     # second radio for dual-band (e.g. radio1); leave blank for single-band
SSID=BTHub6-3K7P
ENCRYPTION=psk2                  # WPA2; use psk+psk2 only for devices that don't support WPA2

SUBNET=192.168.2                 # router gets .1, clients .100–.249
RATE_LIMIT=500kbit               # aggregate cap for the whole network; 0 to disable
RATE_LIMIT_PER_DEVICE=           # per-device cap (e.g. 250kbit); leave blank to disable
DNS_SERVER=1.1.1.3               # Cloudflare for Families (blocks malware + adult content)
IPV6=no                          # yes to enable IPv6 (DHCPv6 + RA); DNS_SERVER_V6 auto-derived
LAN_ACCESS=yes                   # yes = LAN devices can reach untrusted devices (not vice versa)
ALLOWLIST=yes                    # only listed MACs get internet; see /etc/untrusted-allowed-macs

ISOLATE=yes                      # clients cannot talk to each other
DOT=no                           # yes = DNS via https-dns-proxy (encrypted DoT/DoH)
ALLOWED_PORTS=                   # restrict outbound ports; blank = allow all
VLAN_ID=                         # 802.1Q VLAN ID to bridge into this network e.g. 20 (blank = WiFi only)
VLAN_TRUNK=                      # physical trunk interface e.g. eth0 (required when VLAN_ID is set)
NOTIFY_URL=                      # ntfy.sh URL for new device alerts
DEFAULT_DURATION=24h             # pre-selected duration in the approval form (1h 6h 12h 24h 2d 7d 30d)
MAX_DURATION=30d                 # hide longer durations from the form (1h 6h 12h 24h 2d 7d 30d)
REASON_REQUIRED=no               # yes = approver must enter a reason before granting access
BANDWIDTH_THRESHOLD_MB=0         # alert when a device transfers this many MB in a session; 0 = disabled
SHOW_QR=no                       # yes = show WiFi QR code and password in the status dashboard
NOTIFY_JOIN=no                   # yes = send a push notification each time a device joins
JOIN_APPROVAL=no                 # yes = block internet until owner approves each new device (requires NOTIFY_URL)
ROTATE_PASSWORD=no               # yes = show a "Rotate password" button in the status dashboard
DESCRIPTION=IoT / untrusted devices  # optional label shown in the status dashboard
MDNS=no                          # yes = reflect mDNS from LAN
