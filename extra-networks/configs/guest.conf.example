# Copy to configs/guest.conf and set WIFI_KEY before running:
#   sh install.sh configs/guest.conf
# configs/*.conf is gitignored and never committed.

WIFI_KEY=                        # min 8 chars

IFACE=guest
RADIO=radio0                     # radio0 = 2.4GHz, radio1 = 5GHz
RADIO_EXTRA=                     # second radio for dual-band (e.g. radio1); leave blank for single-band
SSID=                            # your guest network name
ENCRYPTION=sae                   # WPA3 only; use sae-mixed for WPA3+WPA2 fallback

SUBNET=192.168.3                 # router gets .1, clients .100–.249
RATE_LIMIT=10mbit                # aggregate cap for the whole network; 0 to disable
RATE_LIMIT_PER_DEVICE=5mbit      # per-device cap so one device can't hog the shared limit
DNS_SERVER=1.1.1.3               # Cloudflare for Families; use 1.1.1.1 for no filtering
IPV6=no                          # yes to enable IPv6 (DHCPv6 + RA); DNS_SERVER_V6 auto-derived
LAN_ACCESS=no                    # yes = LAN devices can reach guest devices (not vice versa)
ALLOWLIST=no                     # open to any device

ISOLATE=yes                      # clients cannot talk to each other (recommended for guests)
DOT=no                           # yes = DNS via https-dns-proxy (encrypted DoT/DoH); requires https-dns-proxy
ALLOWED_PORTS=                   # restrict outbound ports e.g. "80 443"; blank = allow all
VLAN_ID=                         # 802.1Q VLAN ID to bridge into this network e.g. 20 (blank = WiFi only)
VLAN_TRUNK=                      # physical trunk interface e.g. eth0 (required when VLAN_ID is set)
NOTIFY_URL=                      # ntfy.sh URL for new device alerts e.g. https://ntfy.sh/my-topic
DEFAULT_DURATION=24h             # pre-selected duration in the approval form (1h 6h 12h 24h 2d 7d 30d)
MAX_DURATION=30d                 # hide longer durations from the form (1h 6h 12h 24h 2d 7d 30d)
REASON_REQUIRED=no               # yes = approver must enter a reason before granting access
BANDWIDTH_THRESHOLD_MB=0         # alert when a device transfers this many MB in a session; 0 = disabled
SHOW_QR=yes                      # yes = show WiFi QR code and password in the status dashboard
NOTIFY_JOIN=yes                  # yes = send a push notification each time a device joins
JOIN_APPROVAL=no                 # yes = block internet until owner approves each new device (requires NOTIFY_URL)
ROTATE_PASSWORD=yes              # yes = show a "Rotate password" button in the status dashboard
DESCRIPTION=Guest WiFi           # optional label shown in the status dashboard
MDNS=no                          # yes = reflect mDNS from LAN (enables casting, AirPrint, etc.)
ACCESS_HOURS=                    # restrict internet to hours e.g. "8-23"; blank = always on (set via access-schedule.sh)
