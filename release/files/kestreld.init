#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

PORT=8080

start_service() {
	procd_open_instance
	procd_set_param command /usr/bin/kestreld "$PORT"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "network"
}
