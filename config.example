# Copy this file to 'config' and fill in WIFI_KEY before running install.sh.
# 'config' is gitignored and never committed.

# WiFi password for the untrusted network.
# Min 8 characters, no spaces.
WIFI_KEY=

# UCI name of the wireless section to configure (run: uci show wireless).
WIFI_UCI=nestsetup

# SSID broadcast name.
SSID=BTHub6-3K7P

# UCI interface name created for the untrusted network.
IFACE=untrusted

# Subnet — router gets .1, clients get .100–.249.
# Must not overlap with your LAN (default: 192.168.1.0/24).
SUBNET=192.168.2

# Download rate limit applied to the untrusted bridge (tc tbf).
RATE_LIMIT=1mbit

# DNS server given to untrusted clients via DHCP.
# 1.1.1.3 = Cloudflare for Families (blocks malware + adult content).
# 1.1.1.1 = plain Cloudflare (no filtering).
DNS_SERVER=1.1.1.3
